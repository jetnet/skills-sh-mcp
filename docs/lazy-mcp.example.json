{
  "transport": {
    "type": "http",
    "port": 8000,
    "host": "localhost",
    "path": "/mcp"
  },
  "logging": {
    "format": "plain"
  },
  "servers": [
    {
      "name": "skills-sh",
      "description": "Find online skills from skills.sh",
      "command": ["node", "/absolute/path/to/skills-sh-mcp/src/cli.js"],
      "env": {
        "SKILLS_SH_CACHE_DIR": "${HOME}/.cache/skills-sh-mcp"
      }
    }
  ]
}
